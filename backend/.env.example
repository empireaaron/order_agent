# Application Settings
DEBUG=false
APP_NAME="TicketBot - 智能客服工单系统"

# CORS Configuration
# 生产环境必须限制具体域名，多个域名用逗号分隔
# 例如: CORS_ORIGINS="https://admin.yourdomain.com,https://widget.yourdomain.com"
# 开发环境可保持默认: CORS_ORIGINS="*"
CORS_ORIGINS="*"

# MySQL Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=ticket_bot

# Milvus Vector Database
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DB_NAME=default

# LLM Configuration (OpenAI)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# LLM Configuration (DashScope - 阿里云)
# OPENAI_API_KEY=your_dashscope_api_key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen3.5-flash

# LLM Configuration (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# LLM Configuration (Groq)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama3-70b-8192

# LLM Configuration (Ollama - Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Embedding Model
EMBEDDING_MODEL=text-embedding-v2

# LangChain Settings
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=ticket-bot

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production-use-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=false

# Redis Configuration (Optional - for distributed memory storage)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Set to true to enable Redis storage
REDIS_ENABLED=false

# Short Term Memory Configuration
# 短期记忆配置：控制对话历史保留策略
STM_MAX_MESSAGES=20        # 每个用户最多保留消息数（含摘要）
STM_BUFFER_SIZE=6          # 保留最近 N 条消息原文
STM_SUMMARY_TRIGGER=10     # 超过 N 条时触发摘要生成
STM_EXPIRE_SECONDS=1800    # 记忆过期时间（秒，默认30分钟）

# Document Processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50
